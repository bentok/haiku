<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <RootNamespace>HaikuCloud</RootNamespace>
    </PropertyGroup>
    <ItemGroup>
        <Content Include="cdk.json"/>
    </ItemGroup>
    <ItemGroup>
        <Compile Include="HaikuStack.fs"/>
        <Compile Include="Program.fs"/>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Amazon.CDK.Lib" Version="2.245.0"/>
        <PackageReference Include="Constructs" Version="[10.5.0,11.0.0)"/>
    </ItemGroup>
</Project>
