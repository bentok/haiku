---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HaikuCard from '../../components/HaikuCard.astro';
import { getSortedHaiku } from '../../lib/haiku';

const all = await getSortedHaiku();
---

<BaseLayout title="archive — nephesh" activeNav="archive">
  <h1 class="title">archive</h1>
  <p class="section-label">{all.length} entries</p>

  <div class="grid">
    {all.map((h) => (
      <HaikuCard lines={h.data.lines} date={h.data.date} size="sm" href={`/haiku/${h.id}/`} />
    ))}
  </div>
</BaseLayout>

<style>
  .title {
    text-align: center;
    font-family: var(--font-hand);
    font-size: var(--text-xl);
    color: var(--ink-700);
    transform: rotate(-1deg);
    margin: 0;
    font-weight: 400;
  }

  .section-label {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-family: var(--font-typewriter);
    font-size: var(--text-xs);
    color: var(--text-faint);
    margin: var(--space-3) 0 var(--space-8);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-6);
    max-width: var(--max-width-reading);
    margin: 0 auto;
  }
</style>
