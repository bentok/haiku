---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HaikuCard from '../../components/HaikuCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('haiku');
  return all.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
---

<BaseLayout title={`${entry.data.lines[0]} — nephesh`}>
  <div class="detail">
    <HaikuCard lines={entry.data.lines} date={entry.data.date} />
    <a class="back" href="/archive/">← back to archive</a>
  </div>
</BaseLayout>

<style>
  .detail {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .detail :global(.card) {
    width: 480px;
  }

  .back {
    font-family: var(--font-typewriter);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .back:hover {
    color: var(--accent-primary);
  }
</style>
