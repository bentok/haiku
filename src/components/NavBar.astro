---
interface Props {
  active?: 'home' | 'archive' | 'forms' | 'about';
}

const { active } = Astro.props;

const links = [
  { key: 'home', label: 'home', href: '/' },
  { key: 'archive', label: 'archive', href: '/archive/' },
  { key: 'forms', label: 'the forms', href: '/forms/' },
  { key: 'about', label: 'about', href: '/about/' },
] as const;
---

<nav>
  <a href="/" class="wordmark">nephesh</a>
  <div class="links">
    {links.map((l) => (
      <a href={l.href} class:list={{ active: active === l.key }}>{l.label}</a>
    ))}
  </div>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) var(--space-6);
    border-bottom: var(--border-hairline);
    font-family: var(--font-typewriter);
  }

  .wordmark {
    font-family: var(--font-hand);
    font-size: var(--text-lg);
    color: var(--ink-700);
    transform: rotate(-1deg);
  }

  .links {
    display: flex;
    gap: var(--space-6);
  }

  .links a {
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: color var(--duration-fast) var(--ease-settle), border-color var(--duration-fast) var(--ease-settle);
  }

  .links a:hover {
    color: var(--accent-primary);
  }

  .links a.active {
    color: var(--accent-primary);
    border-bottom-color: var(--accent-primary);
  }
</style>
